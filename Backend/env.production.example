# =============================================================================
# Variables de entorno requeridas para producción
# Copiar este archivo, rellenar los valores reales y NO subir al repositorio
# =============================================================================

# Base de datos PostgreSQL
ConnectionStrings__DefaultConnection=Host=localhost;Port=5432;Database=LavanderiaDB;Username=lavanderia_user;Password=TU_PASSWORD_AQUI

# JWT — mínimo 32 caracteres, generado aleatoriamente
JwtSettings__SecretKey=GENERA_UNA_CLAVE_SEGURA_DE_AL_MENOS_32_CHARS

# Correo SMTP (Gmail App Password)
ReportSettings__SmtpUser=deepsoftbot@gmail.com
ReportSettings__SmtpPassword=TU_APP_PASSWORD_GMAIL

# URL del frontend en producción (para CORS)
# Editar directamente en appsettings.Production.json: AllowedOrigins
